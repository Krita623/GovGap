# RPC endpoints used by current samples.
MAINNET_RPC_URL=
ARBITRUM_RPC_URL=

# Detector-local ABI acquisition.
# Optional. If unset, the detector still uses local data/abis and Sourcify, but
# some unknown selectors may remain unresolved.
ETHERSCAN_API_KEY=
DAO_RISK_ABI_FETCH_SOURCIFY=true
DAO_RISK_ABI_FETCH_ETHERSCAN=true
DAO_RISK_ABI_REFRESH_EXISTING=true
DAO_RISK_ABI_FETCH_IMPLEMENTATION_RPC=true
DAO_RISK_ABI_FETCH_SLEEP_SECONDS=0.15
DAO_RISK_ABI_FETCH_MAX_RETRIES=2

# Optional executable paths. Leave empty to use PATH resolution.
# On Windows with Anvil installed in WSL, use:
# ANVIL_COMMAND=wsl anvil
ANVIL_COMMAND=wsl anvil
ANVIL_HOST=127.0.0.1
ANVIL_PORT=8545
ANVIL_RPC_URL=http://127.0.0.1:8545

# Optional LLM configuration.
# LLM is only allowed for proposal text semantic extraction.
# For OpenAI-compatible third-party providers, set LLM_BASE_URL.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
